# Server health check secrets.
# Real keys are auto-generated by the app when you save checks in /config/server-health.
# Example key format:
# SLA_SERVER_HEALTH_<CHECK_ID>_PASSWORD="your-password"
# SLA_SERVER_HEALTH_<CHECK_ID>_BEARER_TOKEN="your-token"

# SMTP settings for email alerts
# Required for alert delivery:
# SLA_ALERT_SMTP_HOST="smtp.example.com"
# SLA_ALERT_SMTP_PORT="587"
# SLA_ALERT_FROM="sla-monitor@example.com"
#
# Optional auth:
# SLA_ALERT_SMTP_USERNAME="smtp-user"
# SLA_ALERT_SMTP_PASSWORD="smtp-password"
#
# Optional behavior:
# SLA_ALERT_SMTP_USE_TLS="true"
# SLA_ALERT_SMTP_USE_SSL="false"
# SLA_ALERT_SUBJECT_PREFIX="[SLA Server Health]"
# SLA_ALERT_REMINDER_SECONDS="900"

# Release tracker (Outlook Win32 email tracking)
# Runs only on Windows hosts with pywin32 installed.
# Optional:
# SLA_RELEASE_OUTLOOK_MAILBOX="shared-mailbox@company.com"
# SLA_RELEASE_OUTLOOK_FOLDER_PATH="Inbox\\Deployments"
# SLA_RELEASE_SUBJECT_FILTER="Deployment"
# SLA_RELEASE_SENDER_FILTER="release-bot@company.com"
# SLA_RELEASE_ONLY_UNSEEN="true"
# SLA_RELEASE_MARK_SEEN="false"
# SLA_RELEASE_ONLY_NEWER_THAN_LAST_RUN="true"
# SLA_RELEASE_POLL_INTERVAL_SECONDS="180"
